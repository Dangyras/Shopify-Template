{% assign ss = section.settings %}

#section__{{ section.id }} {
{%- if custom_styles != blank -%}
  {{ custom_styles }}
{%- endif -%}

{% comment %} SECTION SPACING {% endcomment %}
{%- if ss.section_padding_1 != blank -%}--section--paddingTop_1: {{ ss.section_padding_1 }}rem;{%- endif -%}
{%- if ss.section_padding_1 != blank -%}--section--paddingBottom_1: {{ ss.section_padding_1 }}rem;{%- endif -%}
{%- if ss.section_margin_1 != blank -%}--section--marginTop_1: {{ ss.section_margin_1 }}rem;{%- endif %}
{%- if ss.section_margin_1 != blank -%}--section--marginBottom_1: {{ ss.section_margin_1 }}rem;{%- endif %}

{%- if ss.section_padding_top_1 != blank -%}--section--paddingTop_1: {{ ss.section_padding_top_1 }}rem;{%- endif -%}
{%- if ss.section_padding_bottom_1 != blank -%}--section--paddingBottom_1: {{ ss.section_padding_bottom_1 }}rem;{%- endif -%}
{%- if ss.section_margin_top_1 != blank -%}--section--marginTop_1: {{ ss.section_margin_top_1 }}rem;{%- endif -%}
{%- if ss.section_margin_bottom_1 != blank -%}--section--marginBottom_1: {{ ss.section_margin_bottom_1 }}rem;{%- endif -%}

{% comment %} CONTENT SPACING {% endcomment %}
{%- if ss.content_padding_1 != blank -%}--content--paddingTop_1: {{ ss.content_padding_1 }}rem;{%- endif -%}
{%- if ss.content_padding_1 != blank -%}--content--paddingBottom_1: {{ ss.content_padding_1 }}rem;{%- endif -%}
{%- if ss.content_padding_2 != blank -%}--content--paddingSides_1: {{ ss.content_padding_2 }}rem;{%- endif -%}
{%- if ss.content_padding_3 != blank -%}--content--padding_3: {{ ss.content_padding_3 }}rem;{%- endif -%}

{% comment %} SECTION BACKGROUNDS {% endcomment %}
{%- if ss.section_background_1 != blank or ss.section_background_1 != blank != "rgba(0,0,0,0)" -%}--section--background_1: {{ ss.section_background_1 }};{%- endif -%}

{% comment %} CONTENT BACKGROUNDS {% endcomment %}
{%- if ss.content_background_1 != blank or ss.content_background_1 != "rgba(0,0,0,0)" -%}--content--background_1: {{ ss.content_background_1 }};{%- endif -%}
{%- if ss.content_background_2 != blank or ss.content_background_2 != "rgba(0,0,0,0)" -%}--content--background_2: {{ ss.content_background_2 }};{%- endif -%}
{%- if ss.content_background_3 != blank or ss.content_background_3 != "rgba(0,0,0,0)" -%}--content--background_3: {{ ss.content_background_3 }};{%- endif -%}
{%- if ss.content_background_4 != blank or ss.content_background_4 != "rgba(0,0,0,0)" -%}--content--background_4: {{ ss.content_background_4 }};{%- endif -%}
{%- if ss.content_background_5 != blank or ss.content_background_5 != "rgba(0,0,0,0)" -%}--content--background_5: {{ ss.content_background_5 }};{%- endif -%}

{% comment %} TEXTS {% endcomment %}
{%- if ss.content_text_1 != blank or ss.content_text_1 != "rgba(0,0,0,0)" -%}--content--colour_1: {{ ss.content_text_1 }};{%- endif %}
{%- if ss.content_text_1 != blank or ss.content_text_1 != "rgba(0,0,0,0)" -%}--content--colourRGB_1: {{ ss.content_text_1 | color_extract: 'red' }} {{ ss.content_text_1 | color_extract: 'green' }} {{ ss.content_text_1 | color_extract: 'blue' }};{%- endif %}
{%- if ss.content_text_2 != blank or ss.content_text_2 != "rgba(0,0,0,0)" -%}--content--colour_2: {{ ss.content_text_2 }};{%- endif %}
{%- if ss.content_text_2 != blank or ss.content_text_2 != "rgba(0,0,0,0)" -%}--content--colourRGB_2: {{ ss.content_text_2 | color_extract: 'red' }} {{ ss.content_text_2 | color_extract: 'green' }} {{ ss.content_text_2 | color_extract: 'blue' }};{%- endif %}
{%- if ss.content_text_3 != blank or ss.content_text_3 != "rgba(0,0,0,0)" -%}--content--colour_3: {{ ss.content_text_3 }};{%- endif %}
{%- if ss.content_text_3 != blank or ss.content_text_3 != "rgba(0,0,0,0)" -%}--content--colourRGB_3: {{ ss.content_text_3 | color_extract: 'red' }} {{ ss.content_text_3 | color_extract: 'green' }} {{ ss.content_text_3 | color_extract: 'blue' }};{%- endif %}
{%- if ss.content_text_4 != blank or ss.content_text_4 != "rgba(0,0,0,0)" -%}--content--colour_4: {{ ss.content_text_4 }};{%- endif %}
{%- if ss.content_text_4 != blank or ss.content_text_4 != "rgba(0,0,0,0)" -%}--content--colourRGB_4: {{ ss.content_text_4 | color_extract: 'red' }} {{ ss.content_text_4 | color_extract: 'green' }} {{ ss.content_text_4 | color_extract: 'blue' }};{%- endif %}
{%- if ss.content_text_5 != blank or ss.content_text_5 != "rgba(0,0,0,0)" -%}--content--colour_5: {{ ss.content_text_5 }};{%- endif %}
{%- if ss.content_text_5 != blank or ss.content_text_5 != "rgba(0,0,0,0)" -%}--content--colourRGB_5: {{ ss.content_text_5 | color_extract: 'red' }} {{ ss.content_text_5 | color_extract: 'green' }} {{ ss.content_text_5 | color_extract: 'blue' }};{%- endif %}

{%- if ss.content_accent_1 != blank or ss.content_accent_1 != "rgba(0,0,0,0)" -%}--content--accent_1: {{ ss.content_accent_1 }};{%- endif -%}
{%- if ss.content_accent_2 != blank or ss.content_accent_2 != "rgba(0,0,0,0)" -%}--content--accent_2: {{ ss.content_accent_2 }};{%- endif -%}
{%- if ss.content_accent_3 != blank or ss.content_accent_3 != "rgba(0,0,0,0)" -%}--content--accent_3: {{ ss.content_accent_3 }};{%- endif -%}
{%- if ss.content_accent_4 != blank or ss.content_accent_4 != "rgba(0,0,0,0)" -%}--content--accent_4: {{ ss.content_accent_4 }};{%- endif -%}
{%- if ss.content_accent_5 != blank or ss.content_accent_5 != "rgba(0,0,0,0)" -%}--content--accent_5: {{ ss.content_accent_5 }};{%- endif -%}

{% comment %} BUTTONS {% endcomment %}
{%- if ss.button_text_1 != blank or ss.button_text_1 != "rgba(0,0,0,0)" -%}--section--buttonText_1: {{ ss.button_text_1 }};{%- endif %}
{%- if ss.button_text_1 != blank or ss.button_text_1 != "rgba(0,0,0,0)" -%}--section--buttonTextHover_1: {{ ss.button_text_1 }};{%- endif %}
{%- if ss.button_background_1 != blank or ss.button_background_1 != "rgba(0,0,0,0)" -%}--section--buttonBackground_1: {{ ss.button_background_1 }};{%- endif %}
{%- if ss.button_background_1 != blank or ss.button_background_1 != "rgba(0,0,0,0)" -%}--section--buttonBackgroundHover_1: {{ ss.button_background_1 }};{%- endif %}
{%- if ss.button_text_hover_1 != blank or ss.button_text_hover_1 != "rgba(0,0,0,0)" -%}--section--buttonTextHover_1: {{ ss.button_text_hover_1 }};{%- endif %}
{%- if ss.button_background_hover_1 != blank or ss.button_background_hover_1 != "rgba(0,0,0,0)" -%}--section--buttonBackgroundHover_1: {{ ss.button_background_hover_1 }};{%- endif %}

{%- if ss.button_text_2 != blank or ss.button_text_2 != "rgba(0,0,0,0)" -%}--section--buttonText_2: {{ ss.button_text_2 }};{%- endif %}
{%- if ss.button_text_2 != blank or ss.button_text_2 != "rgba(0,0,0,0)" -%}--section--buttonTextHover_2: {{ ss.button_text_2 }};{%- endif %}
{%- if ss.button_background_2 != blank or ss.button_background_2 != "rgba(0,0,0,0)" -%}--section--buttonBackground_2: {{ ss.button_background_2 }};{%- endif %}
{%- if ss.button_background_2 != blank or ss.button_background_2 != "rgba(0,0,0,0)" -%}--section--buttonBackgroundHover_2: {{ ss.button_background_2 }};{%- endif %}
{%- if ss.button_text_hover_2 != blank or ss.button_text_hover_2 != "rgba(0,0,0,0)" -%}--section--buttonTextHover_2: {{ ss.button_text_hover_2 }};{%- endif %}
{%- if ss.button_background_hover_2 != blank or ss.button_background_hover_2 != "rgba(0,0,0,0)" -%}--section--buttonBackgroundHover_2: {{ ss.button_background_hover_2 }};{%- endif %}

{% comment %} ELEMENT SPACING {% endcomment %}
{%- if ss.element_margin_1 != blank -%}--element--marginBottom_1: {{ ss.element_margin_1 }}rem;{%- endif %}
{%- if ss.element_margin_2 != blank -%}--element--marginBottom_2: {{ ss.element_margin_2 }}rem;{%- endif %}
{%- if ss.element_margin_3 != blank -%}--element--marginBottom_3: {{ ss.element_margin_3 }}rem;{%- endif %}

{%- if ss.element_spacing_1 != blank -%}--element--spacing_1: {{ ss.element_spacing_1 }}rem;{%- endif %}
{%- if ss.element_spacing_2 != blank -%}--element--spacing_2: {{ ss.element_spacing_2 }}rem;{%- endif %}
{%- if ss.element_spacing_3 != blank -%}--element--spacing_3: {{ ss.element_spacing_3 }}rem;{%- endif %}

{%- if ss.element_width_1 != 0 -%}--element--width_1: {{ ss.element_width_1 }}rem;{%- endif -%}
{%- if ss.custom_width_1 != 0 -%}--custom--width_1: {{ ss.custom_width_1 }}rem;{%- endif -%}

{%- if ss.aspect_ratio_desktop_1 != blank -%}--section--ratioDesktop_1: {{ ss.aspect_ratio_desktop_1 }};{%- endif -%}
{%- if ss.aspect_ratio_mobile_1 != blank -%}--section--ratioMobile_1: {{ ss.aspect_ratio_mobile_1 }};{%- endif -%}

{% comment %} MOBILE {% endcomment %}
{%- if ss.mobile_modifier_1 != blank -%}
  {% if ss.mobile_modifier_1 > 0 %}
    --section--modifierSmall_1: {{ ss.mobile_modifier_1 | divided_by: 100.00 | plus: 1 }};
  {% elsif ss.mobile_modifier_1 == 0 %}
    --section--modifierSmall_1: {{ 1 }};
  {% elsif ss.mobile_modifier_1 == '-100' %}
    --section--modifierSmall_1: {{ 2 }};
  {% else %}
    --section--modifierSmall_1: {{ ss.mobile_modifier_1 | abs | divided_by: 100.00 | minus: 1 | abs }};
  {% endif %}
{%- endif -%}

{%- if ss.mobile_modifier_2 != blank -%}
  {% if ss.mobile_modifier_2 > 0 %}
    --section--modifierSmall_2: {{ ss.mobile_modifier_2 | divided_by: 100.00 | plus: 1 }};
  {% elsif ss.mobile_modifier_2 == 0 %}
    --section--modifierSmall_2: {{ 1 }};
  {% elsif ss.mobile_modifier_2 == '-100' %}
    --section--modifierSmall_2: {{ 2 }};
  {% else %}
    --section--modifierSmall_2: {{ ss.mobile_modifier_2 | abs | divided_by: 100.00 | minus: 1 | abs }};
  {% endif %}
{%- endif -%}
}
